# Backend Environment Variables (Example)

# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=root
DB_NAME=fayver_db
DB_CONNECTION_LIMIT=10

# JWT Configuration
SECRET_JWT_KEY=your_secret_jwt_key_here

# Password Hashing
SALT_ROUNDS=10

# CORS Configuration
CORS_ORIGIN=http://localhost:5173
